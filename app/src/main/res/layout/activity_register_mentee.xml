<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/loging"
    tools:context=".Register_Mentee">
    <TextView
        android:id="@+id/textView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="70dp"
        android:layout_marginEnd="87dp"
        android:fontFamily="@font/abril_fatface"
        android:text="Register Here"
        android:textAppearance="@style/TextAppearance.AppCompat.Large"
        android:textColor="#000"
        android:textSize="40sp"
        android:textStyle="bold" />
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0379FF"
        app:subtitleTextAppearance="@style/TextAppearance.AppCompat.Large"
        app:subtitleTextColor="#171616"
        app:title="Mentor Mentee"
        app:titleTextColor="@color/black" />

    <EditText
        android:id="@+id/username"
        android:layout_width="389dp"
        android:layout_height="70dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="18dp"
        android:layout_marginTop="147dp"
        android:layout_marginEnd="43dp"
        android:layout_marginBottom="16dp"
        android:hint="Enter User Name"
        android:inputType="textEmailAddress"
        android:textColorHint="#050505"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/Emailres"
        android:layout_width="389dp"
        android:layout_height="70dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="21dp"
        android:layout_marginTop="232dp"
        android:layout_marginEnd="40dp"
        android:layout_marginBottom="16dp"
        android:hint="Email"
        android:inputType="textEmailAddress"
        android:textColorHint="#0B0A0A"
        android:textStyle="bold" />


    <EditText
        android:id="@+id/Phonen"
        android:layout_width="389dp"
        android:layout_height="70dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="15dp"
        android:layout_marginTop="336dp"
        android:layout_marginEnd="46dp"
        android:layout_marginBottom="16dp"
        android:hint="Phone Number"
        android:inputType="number"
        android:textColorHint="#131313"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/Passwordres"
        android:layout_width="388dp"
        android:layout_height="55dp"
        android:layout_below="@id/Emailres"
        android:layout_marginStart="16dp"
        android:layout_marginTop="121dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:hint="Password"
        android:inputType="textPassword"
        android:textColorHint="#050505"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/editTextConfirmPassword"
        android:layout_width="385dp"
        android:layout_height="63dp"
        android:layout_below="@+id/Passwordres"
        android:layout_marginStart="16dp"
        android:layout_marginTop="9dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:hint="Confirm Password"
        android:inputType="textPassword"
        android:textColorHint="#090808"
        android:textStyle="bold" />

    <Button
        android:id="@+id/buttonRegister"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/editTextConfirmPassword"
        android:layout_centerHorizontal="true"
        android:layout_marginStart="16dp"
        android:layout_marginTop="35dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#0379FF"
        android:onClick="Click"
        android:text="Register"
        android:textColorHint="#120F0F"
        android:textStyle="bold" />

    <ProgressBar
        android:id="@+id/progressBar"
        style="@style/Widget.AppCompat.ProgressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />

</RelativeLayout>