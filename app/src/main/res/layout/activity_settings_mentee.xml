<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Settings_Mentee">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#027FE3"
        app:title="Mentor Mentee"
        app:titleTextColor="@color/white"/>


    <TextView
        android:id="@+id/contactUsTextViewmen"
        android:layout_width="223dp"
        android:layout_height="wrap_content"
        android:layout_below="@+id/terms_and_condition"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="31dp"
        android:layout_marginEnd="198dp"
        android:clickable="true"
        android:onClick="openContactUs"
        android:text="Contact Us >"
        android:textColor="@color/black"
        android:textSize="24sp" />

    <TextView
        android:id="@+id/terms_and_condition"
        android:layout_width="401dp"
        android:layout_height="42dp"
        android:layout_below="@+id/AboutUsTextViewmen"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="21dp"
        android:layout_marginEnd="91dp"
        android:clickable="true"
        android:onClick="openContactUs"
        android:text="Terms And Condition  >"
        android:textColor="@color/black"
        android:textSize="24sp" />

    <TextView
        android:id="@+id/AboutUsTextViewmen"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_below="@+id/toolbar"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="7dp"
        android:clickable="true"
        android:onClick="openContactUs"
        android:text="About Us >"
        android:textColor="@color/black"
        android:textSize="24sp" />

    <Button
        android:id="@+id/logOutButtonmen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginTop="72dp"
        android:layout_marginEnd="233dp"
        android:layout_marginBottom="388dp"
        android:backgroundTint="@color/blue"
        android:onClick="logOut"
        android:text="Log Out"
        android:textColor="@android:color/white" />

</RelativeLayout>